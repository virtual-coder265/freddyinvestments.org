# Freddy Investments — Environment Configuration
# Copy to .env and adjust for your environment.

# --- Local development ---
APP_ENV=development
APP_URL=http://localhost/freddyinvestments.org

# --- Production (freddyinvestments.org) ---
# APP_ENV=production
# APP_URL=https://freddyinvestments.org

SITE_NAME="Freddy Investments"
CONTACT_EMAIL=mphasifreddyinvestments@gmail.com
APP_KEY="change_me_to_a_random_32_char_hex"

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=freddy_cms
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Production: use credentials from your hosting control panel
# DB_HOST=localhost
# DB_DATABASE=your_cpanel_db_name
# DB_USERNAME=your_cpanel_db_user
# DB_PASSWORD=your_strong_db_password

# Set to false to enable admin CMS on production
ADMIN_DISABLED_IN_PRODUCTION=true

# Only used during initial setup (leave empty for secure random password)
# ADMIN_INITIAL_PASSWORD=
